@startuml
!include ../style.puml

Actor User as user USER_COLOR
Participant ":Ui" as ui UI_COLOR
Participant ":Parser" as parser LOGIC_COLOR_T1
Participant ":CommandRunner" as runner LOGIC_COLOR
Participant ":SKUList" as skuList MODEL_COLOR
Participant ":SKU" as sku MODEL_COLOR_T1
Participant ":SKUTaskList" as taskList MODEL_COLOR_T2

user -> ui ++ : "addsku n/PALLET-A l/A1"
ui -> parser ++ : parse("addsku n/PALLET-A l/A1")
return cmd : ParsedCommand

ui -> runner ++ : run(cmd)
runner -> runner ++ : handleAddSku(cmd)
runner -> runner ++ : Location.valueOf("A1")
return location

runner -> runner ++ : findSku("PALLET-A")
runner -> skuList ++ : getSKUList()
return List<SKU>
return null

runner -> skuList ++ : addSKU("PALLET-A", location)
skuList -> sku ** : create("PALLET-A", location)
activate sku MODEL_COLOR_T1
sku -> taskList ** : create()
sku --> skuList
deactivate sku
return

return
return
return display success message
@enduml